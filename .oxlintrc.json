{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "unicorn", "oxc"],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "max-params": "error",
        "max-lines-per-function": [
            "error",
            {
                "max": 150,
                "skipComments": true,
                "skipBlankLines": true
            }
        ],
        "max-lines": [
            "error",
            {
                "max": 1000,
                "skipComments": true,
                "skipBlankLines": true
            }
        ],
        "typescript/consistent-type-assertions": [
            "error",
            {
                "assertionStyle": "never"
            }
        ]
    },
    "env": {
        "builtin": true
    },
    "overrides": [
        {
            "files": ["src/db-sqlite.ts", "src/migrate-sqlite.ts"],
            "rules": {
                "typescript/consistent-type-assertions": "off"
            }
        }
    ]
}
