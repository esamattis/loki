{
  "name": "hypyt",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate-local.ts",
    "db:dev-user": "node scripts/insert-dev-user.ts",
    "db:list-users": "node scripts/list-users.ts",
    "test:e2e": "playwright test",
    "test:tsc": "tsc --noEmit",
    "test": "pnpm run test:tsc && npm run test:e2e"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@playwright/test": "^1.61.1",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.6.1",
    "wrangler": "^4.17.0"
  }
}
